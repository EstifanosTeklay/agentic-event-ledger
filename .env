DATABASE_URL=postgresql://postgres:123@localhost:5432/ledger
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:123@localhost:5432/ledger

# Projection SLOs (milliseconds)
APPLICATION_SUMMARY_SLO_MS=500
COMPLIANCE_AUDIT_SLO_MS=2000

# Daemon settings
PROJECTION_POLL_INTERVAL_MS=100
PROJECTION_BATCH_SIZE=500
PROJECTION_MAX_RETRIES=3
